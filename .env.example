# API Configuration
VITE_API_BASE_URL=http://localhost:8800/api

# Application Configuration
VITE_APP_NAME=ANTL Script Vendeur
VITE_APP_VERSION=1.0.0

# Environment
VITE_NODE_ENV=development

# Sentry (optionnel — laisser vide en dev pour désactiver)
# Créer un projet React sur https://sentry.io et copier le DSN ici
VITE_SENTRY_DSN=

# WebRTC TURN server (optionnel — pour les appels derrière NAT strict)
VITE_TURN_URL=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
